marketplace.bouchikhi.com {
  root * /usr/share/caddy
  encode gzip zstd

  handle /api/* {
    reverse_proxy https://gateway:10000 {
      transport http {
        tls_insecure_skip_verify
      }
    }
  }

  handle {
    try_files {path} /index.html
    file_server
  }
}

jenkins.bouchikhi.com {
   reverse_proxy buy01-jenkins:8080
}

prometheus.bouchikhi.com {
  reverse_proxy prometheus:9090
}

grafana.bouchikhi.com {
  reverse_proxy grafana:3000
}
